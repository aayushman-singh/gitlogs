# Backend API base URL. Defaults to http://localhost:3000 in code when unset.
VITE_API_BASE=http://localhost:3000

# Feature flags — default OFF. Set to "true" to enable. These gate UI that
# depends on backend routes which are not implemented yet.
# VITE_FEATURE_SCHEDULING=true
# VITE_FEATURE_POST_SETTINGS=true

# Firebase config (client-side; safe to expose)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
