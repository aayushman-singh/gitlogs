{
  "name": "gitlogs",
  "version": "1.0.0",
  "description": "Auto-tweet git commits with AI-generated changelogs - Multi-user commercial edition with rate limiting and queue management",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "dev:all": "concurrently \"pnpm dev\" \"pnpm frontend:dev\"",
    "frontend:dev": "pnpm --dir frontend dev",
    "frontend:build": "pnpm --dir frontend build",
    "frontend:install": "pnpm --dir frontend install",
    "setup": "pnpm install && pnpm frontend:install",
    "build": "pnpm frontend:build",
    "test": "vitest run",
    "test:watch": "vitest",
    "seed": "node scripts/seed.js",
    "index-repo": "node src/repoIndexer.js"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "sql.js": "^1.11.0",
    "twitter-api-sdk": "^1.2.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.9",
    "supertest": "^7.2.2",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "git",
    "twitter",
    "x",
    "changelog",
    "ai",
    "gemini",
    "webhook",
    "automation"
  ]
}
