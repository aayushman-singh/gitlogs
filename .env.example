# ─── gitlogs backend environment ───────────────────────────────────────────
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# All values below are PLACEHOLDERS — no real secret belongs in this file.

# ── Server ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
# Public URL of the frontend (used for CORS + OAuth redirects)
FRONTEND_URL=http://localhost:5173
# Public URL of this backend API
API_BASE_URL=http://localhost:3000

# ── GitHub webhook ────────────────────────────────────────────────────────────
# Shared secret for HMAC verification of incoming webhooks.
# Generate: openssl rand -hex 20
WEBHOOK_SECRET=your_webhook_secret_here
# Comma-separated allowlist of repos that may post. Leave empty to accept all.
ALLOWED_REPOS=your-org/your-repo

# ── GitHub OAuth app (login) ──────────────────────────────────────────────────
# Create at https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret

# ── X / Twitter OAuth2 (PKCE) app ─────────────────────────────────────────────
# Create at https://developer.twitter.com/en/portal/dashboard
OAUTH_CLIENT_ID=your_x_oauth2_client_id
OAUTH_CLIENT_SECRET=your_x_oauth2_client_secret
OAUTH_CALLBACK_URL=http://localhost:3000/auth/x/callback

# ── X / Twitter app API keys (posting) ────────────────────────────────────────
TWITTER_API_KEY=your_api_key
TWITTER_API_SECRET=your_api_secret
TWITTER_BEARER_TOKEN=your_bearer_token
TWITTER_ACCESS_TOKEN=your_access_token
TWITTER_ACCESS_SECRET=your_access_secret
ENABLE_THREADING=true

# ── Gemini ────────────────────────────────────────────────────────────────────
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_PATH=./tweets.db

# ── Admin API ─────────────────────────────────────────────────────────────────
# Bearer token guarding /api/admin/* routes. Generate: openssl rand -hex 32
ADMIN_API_KEY=your_admin_api_key

# ── Queue / rate limiting ─────────────────────────────────────────────────────
QUEUE_MAX_RPM=5              # Requests per minute (15 for free Gemini tier)
QUEUE_MAX_RETRIES=3          # Retry attempts on transient failure
QUEUE_BASE_RETRY_DELAY=2000  # Base backoff delay in ms
USER_QUOTA_LIMIT=1           # Per-user hourly quota

# ── Multi-user tiers ──────────────────────────────────────────────────────────
MULTI_USER_ENABLED=true
FREE_TIER_QUOTA=3
PRO_TIER_QUOTA=500
ENTERPRISE_TIER_QUOTA=5000

# ── Cloudflare (optional, DNS automation) ─────────────────────────────────────
CF_API_TOKEN=your_cloudflare_api_token
