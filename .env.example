# Server
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
API_BASE_URL=http://localhost:3000

# GitHub OAuth
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# X OAuth 2.0 PKCE
OAUTH_CLIENT_ID=your_x_oauth_client_id
OAUTH_CLIENT_SECRET=your_x_oauth_client_secret
OAUTH_CALLBACK_URL=http://localhost:3000/auth/x/callback

# GitHub webhooks
WEBHOOK_SECRET=replace_with_a_random_secret
ALLOWED_REPOS=

# Gemini AI
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash

# Persistence
DATABASE_PATH=./tweets.db
ENABLE_THREADING=true

# Optional admin UI access
ADMIN_API_KEY=
